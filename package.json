{
  "name": "@qinsteam/net-core",
  "version": "0.2.6",
  "type": "module",
  "author": "EtherealMz",
  "email": "EtherealMz@outlook.com",
  "description": "QinsNet核心网络框架核心",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "main": "./dist/net-core.js",
  "types": "./dist/lib/net-core/net-core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/net-core/net-core.d.ts",
      "import": "./dist/net-core.js",
      "require": "./dist/net-core.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "compile": "tsc -p tsconfig.json",
    "server": "tsx dist/examples/server.ts",
    "client": "tsx dist/examples/client.ts",
    "test": "tsx src/examples/test.ts",
    "test:compiled": "node --experimental-specifier-resolution=node src/examples/client.js"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "class-transformer": "^0.5.1",
    "cors": "^2.8.6",
    "deepmerge": "^4.3.1",
    "express": "^5.2.1",
    "loglevel": "^1.9.2",
    "reflect-metadata": "^0.2.2",
    "ts-toolbelt": "^9.6.0",
    "vite-plugin-dts": "^4.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-node": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QinsNet/core.net.qins.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "keywords": [
    "QinsNet核心网络框架"
  ],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/QinsNet/core.net.qins/issues"
  },
  "homepage": "https://github.com/QinsNet/core.net.qins"
}
